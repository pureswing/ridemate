{
  "expo": {
    "name": "RideMate",
    "slug": "ridemate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ridemate",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFAF5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ridemate.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RideMate usa tu ubicación para mostrarte viajes cerca de ti.",
        "NSLocationAlwaysUsageDescription": "RideMate usa tu ubicación para mostrarte viajes cerca de ti."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFAF5"
      },
      "package": "com.ridemate.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "androidStatusBar": {
      "translucent": true,
      "backgroundColor": "#FFFAF5"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFAF5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
